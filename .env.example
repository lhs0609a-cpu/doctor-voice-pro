# =================================================================
# Doctor Voice Pro - 환경 설정 예시
# =================================================================
# 이 파일을 backend/.env로 복사하여 사용하세요
# =================================================================

# =================================================================
# Database 설정
# =================================================================
# SQLite 데이터베이스 경로 (상대 경로 권장)
DATABASE_URL=sqlite:///./app.db

# =================================================================
# Security 설정
# =================================================================
# 🔒 중요: 프로덕션 환경에서는 반드시 변경하세요!
# 생성 방법: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production-minimum-32-characters

# JWT 설정
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =================================================================
# API Keys (선택사항)
# =================================================================
# Anthropic Claude API - AI 기능에 필요
ANTHROPIC_API_KEY=

# OpenAI API (선택사항)
OPENAI_API_KEY=

# =================================================================
# CORS 설정
# =================================================================
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =================================================================
# Application 설정
# =================================================================
ENVIRONMENT=development
APP_NAME=Doctor Voice Pro
VERSION=2.0.0

# =================================================================
# Server 설정
# =================================================================
PORT=8010
HOST=0.0.0.0

# =================================================================
# Logging 설정
# =================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10
LOG_BACKUP_COUNT=5

# =================================================================
# Naver Blog API (선택사항)
# =================================================================
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_CALLBACK_URL=http://localhost:8010/api/v1/naver/auth/callback

# =================================================================
# Naver Search Ad API (키워드 실검색량/경쟁도)
#  네이버 검색광고 > 도구 > API 사용관리 에서 발급 (OpenAPI 키와는 별개)
#  미설정 시 원스톱 마법사의 검색량이 0으로 표시됨
# =================================================================
NAVER_AD_CUSTOMER_ID=
NAVER_AD_API_KEY=
NAVER_AD_SECRET_KEY=

# =================================================================
# Feature Flags
# =================================================================
ENABLE_AI_FEATURES=true
ENABLE_AUTO_SAVE=true
ENABLE_SEO_ANALYSIS=true

# =================================================================
# Performance Monitoring
# =================================================================
PERFORMANCE_MONITORING_ENABLED=true
CPU_THRESHOLD=80
MEMORY_THRESHOLD=80

# =================================================================
# Backup 설정
# =================================================================
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=backups
